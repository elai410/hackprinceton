{
  "manifest_id": "adeept_5dof_v1",
  "robot_label": "Adeept 5 DOF",
  "skills": [
    {
      "id": "go_home",
      "display_name": "Go to home pose",
      "description": "Move all joints to the known safe home configuration.",
      "parameters": {},
      "constraints": {}
    },
    {
      "id": "set_joint_angle",
      "display_name": "Set joint angle",
      "description": "Set a single joint to a target angle in degrees. Joint 0 is the base rotation, joints 1-3 are arm segments, joint 4 is the wrist.",
      "parameters": {
        "joint_index": { "type": "integer", "minimum": 0, "maximum": 4 },
        "angle_deg": { "type": "number", "minimum": -90, "maximum": 90 }
      },
      "constraints": { "max_speed_deg_s": 30 }
    },
    {
      "id": "wave",
      "display_name": "Wave greeting",
      "description": "Perform a gentle waving motion using the upper arm joints.",
      "parameters": {
        "repetitions": { "type": "integer", "minimum": 1, "maximum": 5 }
      },
      "constraints": {}
    },
    {
      "id": "grip_open",
      "display_name": "Open gripper",
      "description": "Open the end effector gripper fully.",
      "parameters": {},
      "constraints": {}
    },
    {
      "id": "grip_close",
      "display_name": "Close gripper",
      "description": "Close the end effector gripper to grip an object.",
      "parameters": {
        "force_pct": { "type": "integer", "minimum": 10, "maximum": 100 }
      },
      "constraints": {}
    },
    {
      "id": "pan_left",
      "display_name": "Pan left",
      "description": "Rotate the base joint to the left by a given number of degrees.",
      "parameters": {
        "degrees": { "type": "number", "minimum": 1, "maximum": 90 }
      },
      "constraints": {}
    },
    {
      "id": "pan_right",
      "display_name": "Pan right",
      "description": "Rotate the base joint to the right by a given number of degrees.",
      "parameters": {
        "degrees": { "type": "number", "minimum": 1, "maximum": 90 }
      },
      "constraints": {}
    },
    {
      "id": "tilt_up",
      "display_name": "Tilt up",
      "description": "Tilt the arm upward by raising joint 1.",
      "parameters": {
        "degrees": { "type": "number", "minimum": 1, "maximum": 45 }
      },
      "constraints": {}
    },
    {
      "id": "tilt_down",
      "display_name": "Tilt down",
      "description": "Tilt the arm downward by lowering joint 1.",
      "parameters": {
        "degrees": { "type": "number", "minimum": 1, "maximum": 45 }
      },
      "constraints": {}
    }
  ]
}
