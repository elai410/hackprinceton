{
  "config_id": "demo-bindings",
  "bindings": [
    {
      "binding_id": "speech-hello-wave",
      "display_name": "Wave when you say hello",
      "trigger": {
        "type": "speech",
        "payload_match": { "normalized": "~hello" }
      },
      "plan": {
        "plan_id": "wave-three-times",
        "steps": [
          { "skill_id": "go_home",   "arguments": {} },
          { "skill_id": "wave",      "arguments": { "repetitions": 3 } },
          { "skill_id": "go_home",   "arguments": {} }
        ]
      }
    },
    {
      "binding_id": "speech-goodnight-oled",
      "display_name": "Show goodnight + lower arm",
      "trigger": {
        "type": "speech",
        "payload_match": { "normalized": "~goodnight" }
      },
      "plan": {
        "plan_id": "goodnight",
        "steps": [
          { "skill_id": "oled_text",       "arguments": { "text": "Goodnight" } },
          { "skill_id": "set_joint_angle", "arguments": { "joint_index": 1, "angle_deg": 30 } }
        ]
      }
    },
    {
      "binding_id": "key-space-home",
      "display_name": "Spacebar returns to home",
      "trigger": {
        "type": "key",
        "payload_match": { "key": "space", "action": "press" }
      },
      "plan": {
        "plan_id": "space-go-home",
        "steps": [{ "skill_id": "go_home", "arguments": {} }]
      }
    },
    {
      "binding_id": "clap-twice-wave",
      "display_name": "Two claps = wave hello",
      "trigger": {
        "type": "clap",
        "payload_match": { "count": 2 }
      },
      "plan": {
        "plan_id": "clap-wave",
        "steps": [{ "skill_id": "wave", "arguments": { "repetitions": 2 } }]
      }
    }
  ]
}
