# Companion server
COMPANION_HOST=0.0.0.0
COMPANION_PORT=8000

# Adapter: "mock" | "adeept"
ADAPTER=mock

# Paths
MANIFEST_PATH=examples/manifest.adeept.json
FALLBACK_PLAN_PATH=examples/plan.fallback.json
BINDING_STORE_PATH=bindings.json

# Planner
PLANNER_PRIMARY=moonshot
MOONSHOT_API_KEY=
MOONSHOT_BASE_URL=https://api.moonshot.cn/v1
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
PLANNER_MODEL_PRIMARY=moonshot-v1-128k
PLANNER_MODEL_FALLBACKS=gpt-4o-mini
PLANNER_TIMEOUT_S=60

# Mock adapter
EXECUTION_STEP_DELAY_MS=200

# Input adapters (set to true to enable)
INPUTS_CAMERA_ENABLED=false
INPUTS_AUDIO_ENABLED=false
INPUTS_KEYBOARD_ENABLED=true

# Dispatcher behavior when a plan is already running: "drop" | "queue"
DISPATCH_OVERLAP=drop

# Web client — copy to web/.env
# VITE_COMPANION_URL=http://127.0.0.1:8000
