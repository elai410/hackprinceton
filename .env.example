# Companion server
COMPANION_HOST=0.0.0.0
COMPANION_PORT=8000

# Adapter: "mock" | "adeept"
ADAPTER=mock

# Paths
MANIFEST_PATH=examples/manifest.adeept.json
FALLBACK_PLAN_PATH=examples/plan.fallback.json
BINDING_STORE_PATH=bindings.json

# Planner — IFM K2-Think (OpenAI-compatible)
PLANNER_PRIMARY=k2think
K2_API_KEY=
K2_BASE_URL=https://api.k2think.ai/v1
ANTHROPIC_API_KEY=
PLANNER_MODEL_PRIMARY=MBZUAI-IFM/K2-Think-v2
PLANNER_MODEL_FALLBACKS=claude-3-5-sonnet-latest
PLANNER_TIMEOUT_S=60

# Mock adapter
EXECUTION_STEP_DELAY_MS=200

# Adeept hardware (only used when ADAPTER=adeept)
# ADEEPT_PORT=/dev/tty.usbserial-1410   # mac
# ADEEPT_PORT=/dev/ttyUSB0              # linux
# ADEEPT_PORT=COM3                      # windows
ADEEPT_BAUD=115200
ADEEPT_INTERP_HZ=50
ADEEPT_MAX_SPEED_DEG_S=60
ADEEPT_OPEN_RESET_S=2.0
ADEEPT_HANDSHAKE_TIMEOUT_S=8.0

# Input adapters (set to true to enable)
INPUTS_CAMERA_ENABLED=false
INPUTS_AUDIO_ENABLED=false       # amplitude clap detector
INPUTS_KEYBOARD_ENABLED=true
INPUTS_SPEECH_ENABLED=false      # local mic + open-source Whisper STT

# Speech (only used when INPUTS_SPEECH_ENABLED=true)
# Model size:    tiny.en (75MB, fastest)  base.en (150MB, recommended)
#                small.en (500MB, more accurate)
SPEECH_MODEL_SIZE=base.en
SPEECH_LANGUAGE=en               # ISO code; leave blank to auto-detect
SPEECH_DEVICE=cpu                # cpu | cuda | auto
SPEECH_VAD_THRESHOLD=0.015       # raise if it triggers on ambient noise
SPEECH_MIN_SILENCE_MS=700        # trailing silence to end a phrase
SPEECH_MIN_PHRASE_MS=350
SPEECH_MAX_PHRASE_S=8.0

# Dispatcher behavior when a plan is already running: "drop" | "queue"
DISPATCH_OVERLAP=drop

# Web client — copy to web/.env
# VITE_COMPANION_URL=http://127.0.0.1:8000
